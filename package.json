{
  "name": "node-crud-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.10.0"
  },
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --target=node24 --format=esm --outdir=dist --packages=external",
    "start:dev": "tsx watch src/server.ts",
    "start:prod": "npm run build && cross-env NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
