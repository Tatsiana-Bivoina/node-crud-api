{
  "name": "node-crud-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.10.0"
  },
  "scripts": {
    "build": "esbuild src/server.ts src/multi.ts --bundle --platform=node --target=node24 --format=esm --outdir=dist --packages=external",
    "start:dev": "tsx watch src/server.ts",
    "start:prod": "npm run build && cross-env NODE_ENV=production node dist/server.js",
    "start:multi": "tsx src/multi.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.1",
    "eslint": "^9.22.0",
    "eslint-plugin-zod": "^3.5.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  }
}
